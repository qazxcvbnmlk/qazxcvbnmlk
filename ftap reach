})

-- タブ2: カオス
local Tab2 = Window:CreateTab("カオス", 4483345998)

Tab2:CreateButton({
   Name = "全員ラグドール (バナナ)",
   Callback = function()
       local banana = Player.Character:FindFirstChild("Banana") or Player.Backpack:FindFirstChild("Banana")
       if banana then
           banana.Parent = Player.Character
           for _, target in pairs(game.Players:GetPlayers()) do
               if target ~= Player and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                   firetouchinterest(target.Character.HumanoidRootPart, banana.Handle, 0)
                   task.wait(0.01)
                   firetouchinterest(target.Character.HumanoidRootPart, banana.Handle, 1)
               end
           end
       else
           Rayfield:Notify({Title = "エラー", Content = "バナナを持って！", Duration = 2})
       end
   end,
})

-- ループで値を固定
game:GetService("RunService").Heartbeat:Connect(function()
    checkAndAddReach()
end)

-- レイキャストバイパス
local mt = getrawmetatable(game)
local oldNamecall = mt.__namecall
setreadonly(mt, false)
mt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    if (method == "Raycast" or method == "FindPartOnRay") and not checkcaller() then
        if args[2] then
            args[2] = args[2].Unit * REACH_DISTANCE
            return oldNamecall(self, unpack(args))
        end
    end
    return oldNamecall(self, ...)
end)
setreadonly(mt, true)
