local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Ozon Hub | reallfell3",
   LoadingTitle = "モバイルリーチ修正",
   LoadingSubtitle = "by Gemini",
   ConfigurationSaving = {Enabled = true, FolderName = "OzonHub"}
})

local REACH_DISTANCE = 15
local DEFAULT_REACH = 15
local Player = game:GetService("Players").LocalPlayer

-- 関数: リーチ値を確認して追加
local function checkAndAddReach()
    pcall(function()
        local reachNames = {"FartherReach", "DefaultReach", "CurrentReach"}
        for _, name in pairs(reachNames) do
            local obj = Player:FindFirstChild(name)
            if not obj then
                local newObj = Instance.new("NumberValue")
                newObj.Name = name
                newObj.Value = REACH_DISTANCE
                newObj.Parent = Player
            else
                obj.Value = REACH_DISTANCE
            end
        end
    end)
end

-- タブ1
local Tab1 = Window:CreateTab("リーチ", 4483362458)

Tab1:CreateToggle({
   Name = "リーチ有効化 (40スタッド)",
   CurrentValue = false,
   Callback = function(Value)
       if Value then
           REACH_DISTANCE = 40
       else
           REACH_DISTANCE = DEFAULT_REACH
       end
       checkAndAddReach()
   end,
})

Tab1:CreateButton({
   Name = "ライン拡張",
